# ===========================================
# Studio Beatriz Beltrão — Production Environment
# Copie para .env.production e preencha os valores reais
# ===========================================

# Supabase (PostgreSQL)
SUPABASE_URL=https://supabase.com/dashboard/project/YOUR_PROJECT
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
DATABASE_URL=postgresql://postgres.xxx:PASSWORD@aws-region.pooler.supabase.com:5432/postgres

# OpenRouter (LLM Gateway)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# Evolution API (WhatsApp) — já produção
EVOLUTION_API_URL=https://evo.meloagency.com.br
EVOLUTION_API_KEY=your-evolution-api-key
EVOLUTION_INSTANCE_NAME=BeatrizBeltrao

# Google Workspace
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REFRESH_TOKEN=your-google-refresh-token
GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com

# ASAAS (Pagamentos) — SANDBOX para testes
ASAAS_API_KEY=your-asaas-sandbox-api-key
ASAAS_WEBHOOK_TOKEN=your-asaas-webhook-token
ASAAS_ENVIRONMENT=sandbox

# Resend (E-mail)
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=contato@studiobeatrizbeltrao.com.br

# App — PRODUÇÃO
PORT=3001
NODE_ENV=production
CORS_ORIGIN=https://studiobeatrizbeltrao.com.br
DEPOSIT_PERCENTAGE=30
PAYMENT_TIMEOUT_HOURS=24
BUSINESS_HOURS_START=05:00
BUSINESS_HOURS_END=22:00
MAQUIADORA_PHONE=5581951680117
MAQUIADORA_EMAIL=beatriz@studiobeatrizbeltrao.com.br

# Trigger.dev — PRODUÇÃO
TRIGGER_SECRET_KEY=tr_prod_your-trigger-production-key

# Redis (Upstash) — cloud, acessível por API e Trigger.dev
REDIS_URL=rediss://default:your-upstash-password@your-upstash-host.upstash.io:6379

# Sentry — PRODUÇÃO
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=v1.0.0
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project
SENTRY_AUTH_TOKEN=your-sentry-auth-token
